# rai-agent environment configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ═══════════════════════════════════════════════════════════════════
# Authentication — choose ONE method
# ═══════════════════════════════════════════════════════════════════

# Option 1: Claude subscription (Pro/Max)
#   Run `claude setup-token` on your machine to get a long-lived token.
#   Uses your subscription — no extra API charges.
# CLAUDE_CODE_TOKEN=cct_xxxxxxxxxxxxx

# Option 2: Anthropic API key (pay-as-you-go)
#   Get your key at https://console.anthropic.com/
#   Billed at API rates, not subscription rates.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Option 3: AWS Bedrock
#   Uses your AWS account billing.
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# Option 4: Google Vertex AI
#   Uses your GCP project billing.
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=us-east5
# ANTHROPIC_VERTEX_PROJECT_ID=my-project

# Option 5: Azure Foundry
#   Uses your Azure account billing.
# CLAUDE_CODE_USE_FOUNDRY=1
# AZURE_FOUNDRY_RESOURCE=
# AZURE_API_KEY=

# Option 6: LLM Proxy / Gateway
#   Route through your own proxy (e.g. LiteLLM, custom gateway).
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://my-proxy.example.com

# ═══════════════════════════════════════════════════════════════════
# Telegram Bot
# ═══════════════════════════════════════════════════════════════════

# Create a bot via @BotFather on Telegram to get these values.
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_USER_IDS=123456789

# ═══════════════════════════════════════════════════════════════════
# Optional
# ═══════════════════════════════════════════════════════════════════

# RAI_DAEMON_HOST=0.0.0.0
# RAI_DAEMON_PORT=8000
# RAI_BRIEFING_CHAT_ID=
# RAI_BRIEFING_CRON=0 8 * * 1-5
