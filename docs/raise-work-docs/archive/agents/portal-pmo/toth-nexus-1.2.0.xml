            <example>
                ```typescript
                function validateEnvironment() {
                    const required = ['VAR1', 'VAR2'];
                    for (const var of required) {
                        if (!process.env[var]) {
                            throw new Error(`Missing ${var}`);
                        }
                    }
                }
