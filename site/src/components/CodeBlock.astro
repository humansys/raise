---
/**
 * Styled terminal/code display with syntax highlighting via CSS classes.
 * Used on the landing page for the session.py example.
 */
interface Props {
  filename?: string;
}

const { filename = 'session.py' } = Astro.props;
---

<div class="code-block">
  <div class="code-header">
    <span class="code-dot"></span>
    <span class="code-dot"></span>
    <span class="code-dot"></span>
    <span class="code-filename">{filename}</span>
  </div>
  <div class="code-content">
    <slot />
  </div>
</div>

<style>
  .code-block {
    background: var(--color-base-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 10px;
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #fff;
    opacity: 0.4;
  }

  .code-filename {
    margin-left: 0.5rem;
  }

  .code-content {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.9;
    overflow-x: auto;
    color: var(--color-text-primary);
  }

  /* Syntax classes */
  .code-content :global(.kw) { color: var(--color-text-secondary); }
  .code-content :global(.fn) { color: var(--color-warm); }
  .code-content :global(.str) { color: var(--color-text-tertiary); }
  .code-content :global(.cmt) { color: #2a2a2a; font-style: italic; }
  .code-content :global(.num) { color: var(--color-text-secondary); }
</style>
