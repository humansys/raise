---
interface Metric {
  value: string;
  suffix?: string;
  label: string;
  highlight?: boolean;
}

interface Props {
  metrics?: Metric[];
}

const { metrics = [
  { value: '37', label: 'Skills', highlight: true },
  { value: '97', suffix: '%', label: 'Token savings' },
  { value: '15.8', label: 'Story points / day' },
  { value: '1', label: 'Engineer', highlight: true },
] } = Astro.props;
---

<section class="metrics">
  {metrics.map((m) => (
    <div class="metric">
      <div class="metric-value">
        {m.highlight ? <span class="metric-warm">{m.value}</span> : m.value}
        {m.suffix && <span class="metric-suffix">{m.suffix}</span>}
      </div>
      <div class="metric-label">{m.label}</div>
    </div>
  ))}
</section>

<style>
  .metrics {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 3rem 2rem;
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
    background: rgba(18, 18, 18, 0.3);
  }

  .metric {
    text-align: center;
  }

  .metric-value {
    font-size: 2.5rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .metric-warm {
    color: var(--color-warm);
  }

  .metric-suffix {
    font-size: 1.5rem;
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem;
    }

    .metric-value {
      font-size: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .metric-value {
      font-size: 1.5rem;
    }
  }
</style>
