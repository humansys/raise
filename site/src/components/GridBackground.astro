---
/**
 * "The Grid" — background visual system.
 * Grid lines + radial amber glow + CSS-only runners (Tron-style).
 * Runners disabled on mobile for performance.
 */
---

<!-- Grid lines + ambient glow -->
<div class="grid-bg" aria-hidden="true"></div>

<!-- Tron grid runners — CSS-only animated dots with trails -->
<div class="runner runner-h runner-h1" aria-hidden="true"></div>
<div class="runner runner-h runner-h2" aria-hidden="true"></div>
<div class="runner runner-h runner-h3" aria-hidden="true"></div>
<div class="runner runner-h runner-h4" aria-hidden="true"></div>
<div class="runner runner-h runner-h5" aria-hidden="true"></div>
<div class="runner runner-v runner-v1" aria-hidden="true"></div>
<div class="runner runner-v runner-v2" aria-hidden="true"></div>
<div class="runner runner-v runner-v3" aria-hidden="true"></div>
<div class="runner runner-v runner-v4" aria-hidden="true"></div>
<div class="runner runner-v runner-v5" aria-hidden="true"></div>

<style>
  /* Grid background with subtle lines */
  .grid-bg {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image:
      linear-gradient(var(--color-grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-grid-line) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 0;
    pointer-events: none;
  }

  /* Center glow — warm bloom behind hero */
  .grid-bg::before {
    content: '';
    position: absolute;
    top: 10%; left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(194, 129, 61, 0.15) 0%, rgba(194, 129, 61, 0.08) 40%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .grid-bg::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(194, 129, 61, 0.12) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 50%, rgba(255, 255, 255, 0.04) 0%, transparent 50%);
  }

  /* === RUNNERS === */
  .runner {
    position: fixed;
    z-index: 0;
    pointer-events: none;
  }

  /* Horizontal runners */
  .runner-h {
    height: 1px;
    width: 120px;
    background: linear-gradient(90deg, transparent, var(--color-runner-trail) 20%, var(--color-runner-glow) 80%, var(--color-runner));
    opacity: 0;
    animation: run-h 8s linear infinite;
  }

  .runner-h::after {
    content: '';
    position: absolute;
    right: -2px;
    top: -2px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-runner);
    box-shadow: 0 0 8px var(--color-runner-glow), 0 0 20px var(--color-runner-trail);
  }

  /* Vertical runners */
  .runner-v {
    width: 1px;
    height: 120px;
    background: linear-gradient(180deg, transparent, var(--color-runner-trail) 20%, var(--color-runner-glow) 80%, var(--color-runner));
    opacity: 0;
    animation: run-v 10s linear infinite;
  }

  .runner-v::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: -2px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-runner);
    box-shadow: 0 0 8px var(--color-runner-glow), 0 0 20px var(--color-runner-trail);
  }

  /* Snap runners to grid lines (60px grid) with staggered timing */
  .runner-h1 { top: 180px; left: -120px; animation-delay: 4s; animation-duration: 14s; }
  .runner-h2 { top: 420px; left: -120px; animation-delay: 16s; animation-duration: 18s; }
  .runner-h3 { top: 660px; left: -120px; animation-delay: 30s; animation-duration: 12s; }
  .runner-h4 { top: 300px; left: -120px; animation-delay: 44s; animation-duration: 16s; width: 80px; }
  .runner-h5 { top: 540px; left: -120px; animation-delay: 60s; animation-duration: 20s; width: 150px; }

  .runner-v1 { left: 240px; top: -120px; animation-delay: 10s; animation-duration: 22s; }
  .runner-v2 { left: 480px; top: -120px; animation-delay: 24s; animation-duration: 16s; }
  .runner-v3 { left: 720px; top: -120px; animation-delay: 40s; animation-duration: 24s; }
  .runner-v4 { left: 960px; top: -120px; animation-delay: 56s; animation-duration: 18s; height: 80px; }
  .runner-v5 { left: 360px; top: -120px; animation-delay: 70s; animation-duration: 20s; height: 100px; }

  @keyframes run-h {
    0% { transform: translateX(0); opacity: 0; }
    2% { opacity: 0.7; }
    85% { opacity: 0.7; }
    100% { transform: translateX(calc(100vw + 240px)); opacity: 0; }
  }

  @keyframes run-v {
    0% { transform: translateY(0); opacity: 0; }
    2% { opacity: 0.6; }
    85% { opacity: 0.6; }
    100% { transform: translateY(calc(100vh + 240px)); opacity: 0; }
  }

  /* Reduced runners on mobile for performance - keep only 2 */
  @media (max-width: 768px) {
    /* Hide most runners */
    .runner-h2, .runner-h3, .runner-h4, .runner-h5,
    .runner-v2, .runner-v3, .runner-v4, .runner-v5 {
      display: none;
    }

    /* Keep one horizontal and one vertical for visual effect */
    .runner-h1 {
      animation-duration: 10s; /* Faster on mobile */
    }

    .runner-v1 {
      animation-duration: 12s; /* Faster on mobile */
    }

    .grid-bg::before {
      width: 100%;
      height: 400px;
    }
  }
</style>
