---
interface Props {
  icon: string;
  title: string;
  description: string;
  accent?: boolean;
}

const { icon, title, description, accent = false } = Astro.props;
---

<div class="feature-card">
  <div class:list={['feature-icon', { 'feature-icon-accent': accent }]}>
    <Fragment set:html={icon} />
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .feature-card {
    padding: 2rem;
    background: var(--color-base-deep);
    transition: background 0.3s;
  }

  .feature-card:hover {
    background: var(--color-base-surface);
  }

  .feature-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    margin-bottom: 1.25rem;
    font-size: 1rem;
    font-family: var(--font-mono);
    font-weight: 600;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-border-default);
    color: var(--color-text-secondary);
  }

  .feature-icon-accent {
    color: var(--color-warm);
    background: rgba(194, 129, 61, 0.06);
    border-color: rgba(194, 129, 61, 0.15);
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }

  p {
    color: var(--color-text-tertiary);
    font-size: 0.875rem;
    line-height: 1.6;
  }
</style>
