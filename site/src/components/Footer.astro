---
import { getLocaleFromUrl, getLocalizedPath, t } from '../i18n/utils';

const currentYear = new Date().getFullYear();
const locale = getLocaleFromUrl(Astro.url);
const docsHref = getLocalizedPath('/docs', locale);
const blogHref = getLocalizedPath('/blog', locale);
const buildId = `${new Date().toISOString().slice(0, 16).replace('T', ' ')} UTC`;
---

<footer>
  <div class="footer-branding">
    <img src="/logo.svg" alt="RaiSE Framework" class="footer-logo" />
    <span class="footer-copy">&copy; {currentYear} Sistemas Humanos</span>
  </div>
  <div class="footer-links">
    <a href={getLocalizedPath("/#cta", locale)}>{t("footer.github", locale)}</a>
    <a href={docsHref}>{t('footer.docs', locale)}</a>
    <a href={blogHref}>{t('footer.blog', locale)}</a>
    <a href="https://pypi.org/project/rai-cli/" target="_blank" rel="noopener noreferrer">PyPI</a>
  </div>
  <span class="build-id" aria-hidden="true">{buildId}</span>
</footer>

<style>
  footer {
    padding: 3rem 4rem;
    border-top: 1px solid var(--color-border-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--color-text-tertiary);
    font-size: 0.8rem;
  }

  .footer-branding {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-logo {
    height: 40px;
    width: auto;
    display: block;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .footer-logo:hover {
    opacity: 1;
  }

  .footer-copy {
    color: var(--color-text-tertiary);
  }

  .footer-links {
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }

  .build-id {
    position: absolute;
    bottom: 0.5rem;
    right: 1rem;
    font-size: 0.6rem;
    font-family: var(--font-mono);
    color: var(--color-base-deep);
    user-select: all;
  }

  @media (max-width: 768px) {
    footer {
      padding: 2rem 1.5rem;
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
