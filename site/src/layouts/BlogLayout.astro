---
import BaseLayout from './BaseLayout.astro';
import { getLocaleFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
  ogImage?: string;
}

const { title, description, pubDate, updatedDate, author = 'Emilio Hernández', tags = [], ogImage } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const dateLocale = locale === 'es' ? 'es-MX' : 'en-US';

function formatDate(date: Date): string {
  return date.toLocaleDateString(dateLocale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={`${title} — RaiSE`} description={description} ogImage={ogImage}>
  <article class="blog-post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <span class="updated">
            (Updated: <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>)
          </span>
        )}
        <span class="author">by {author}</span>
      </div>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
  }

  .updated {
    color: var(--color-text-tertiary);
  }

  .author {
    color: var(--color-text-secondary);
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .post-description {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .tag {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-border-default);
    border-radius: 4px;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .blog-post {
      padding: 2rem 1.5rem 4rem;
    }

    h1 {
      font-size: 1.75rem;
    }

    .post-meta {
      flex-wrap: wrap;
    }
  }
</style>
