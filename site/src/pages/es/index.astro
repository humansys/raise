---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetricsBar from '../../components/MetricsBar.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const features = [
  {
    icon: '>_',
    title: 'Memoria Neurosimbólica',
    description: 'Contexto basado en grafos que se acumula entre sesiones. La IA recuerda patrones, calibraciones y errores — de forma determinística.',
    accent: false,
  },
  {
    icon: '</>',
    title: 'Skills como Proceso',
    description: 'Flujos de trabajo repetibles codificados como skills, no prompts. Ciclos TDD, descomposición de historias, investigación basada en evidencia — integrados.',
    accent: true,
  },
  {
    icon: '#',
    title: 'Gobernanza Integrada',
    description: 'Guardrails, gates y controles de calidad en cada etapa. No son capas opcionales — son elementos estructurales del framework.',
    accent: false,
  },
  {
    icon: '~',
    title: 'Metodología Lean',
    description: 'El mínimo viable para todo. Heurísticas simples sobre ML complejo. Keyword matching tiene 98% de precisión. La complejidad debe ganarse su lugar.',
    accent: true,
  },
  {
    icon: '$',
    title: 'Toolkit CLI-First',
    description: 'Un comando para construir contexto, consultar patrones, emitir telemetría. Operaciones determinísticas que nunca alucinan.',
    accent: false,
  },
  {
    icon: '&',
    title: 'Humano en el Loop',
    description: 'Jidoka — detenerse ante defectos. La IA pausa cuando hay incertidumbre, no cuando tiene confianza. La confianza se construye, no se asume.',
    accent: true,
  },
];
---

<BaseLayout title="RaiSE Framework — Ingeniería de Software Confiable con IA">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-badge">
      <span class="dot"></span>
      Community Edition — Gratis & Open Source
    </div>
    <h1>
      IA que no<br />
      <span class="highlight">se desvía, no olvida,<br />no corta camino.</span>
    </h1>
    <p class="hero-sub">
      Una metodología lean y toolkit determinístico para ingeniería de software confiable asistida por IA. Comienza gratis. Crece con tu equipo.
    </p>
    <div class="hero-actions">
      <a href="/es/docs" class="btn-cta-primary">Comenzar</a>
      <a href="/es/pricing" class="btn-secondary">Ver Precios &rarr;</a>
    </div>
  </section>

  <!-- Separator -->
  <div class="sep" aria-hidden="true"></div>

  <!-- Metrics -->
  <MetricsBar />

  <!-- Features -->
  <section class="features" id="features">
    <div class="section-label">// capacidades</div>
    <h2 class="section-title">Determinístico donde importa.</h2>
    <p class="section-desc">
      Separar lo que el LLM debe decidir de lo que no. Arneses determinísticos para el proceso. Inferencia probabilística para la creatividad.
    </p>

    <div class="feature-grid">
      {features.map((f) => (
        <FeatureCard
          icon={f.icon}
          title={f.title}
          description={f.description}
          accent={f.accent}
        />
      ))}
    </div>
  </section>

  <!-- Separator -->
  <div class="sep" aria-hidden="true"></div>

  <!-- Code Section -->
  <section class="code-section">
    <div>
      <div class="section-label">// cómo funciona</div>
      <h2 class="section-title">Un ingeniero.<br />Output de equipo completo.</h2>
      <p class="section-desc" style="margin-bottom: 2rem;">
        RaiSE es el sistema operativo del desarrollador asistido por IA. Los skills guían el proceso. La memoria acumula conocimiento. Los gates aseguran calidad.
      </p>
      <p class="section-desc">
        El resultado: una persona entrega lo que antes requería un equipo — con mayor calidad, mejores tests y trazabilidad completa.
      </p>
    </div>
    <CodeBlock filename="terminal">
      <Fragment set:html={`<span class="cmt"># Iniciar sesión con contexto completo</span>
<span class="fn">$</span> rai session start --project . --context

<span class="cmt"># Consultar patrones del grafo de conocimiento</span>
<span class="fn">$</span> rai graph query <span class="str">"testing patterns"</span> --types pattern

<span class="cmt"># Ejecutar ciclo de vida de story</span>
<span class="fn">$</span> /rai-story-run S356.2`} />
    </CodeBlock>
  </section>

  <!-- CTA -->
  <section id="cta" class="cta">
    <h2>Construye con <span class="hl">disciplina</span>.</h2>
    <p>Gratis para desarrolladores individuales. Pro para equipos. Enterprise para industrias reguladas.</p>
    <div class="cta-actions">
      <a href="/es/docs" class="btn-cta-primary">Comenzar</a>
      <a href="/es/pricing" class="btn-secondary">Ver Precios &rarr;</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* === HERO === */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 85vh;
    text-align: center;
    padding: 4rem 2rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    border: 1px solid var(--color-border-default);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    background: rgba(18, 18, 18, 0.6);
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--color-warm);
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(194, 129, 61, 0.6);
    animation: pulse 2.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  h1 {
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 800px;
    margin-bottom: 1.5rem;
    color: var(--color-text-primary);
  }

  .highlight {
    background: linear-gradient(135deg, var(--color-warm-muted), var(--color-warm), var(--color-warm-bright));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: 3rem;
    font-weight: 400;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }


  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    font-family: inherit;
  }

  .btn-secondary:hover {
    border-color: var(--color-text-tertiary);
    background: rgba(255, 255, 255, 0.02);
  }

  /* === SEPARATOR === */
  .sep {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-default), var(--color-warm-dim), var(--color-border-default), transparent);
    opacity: 0.5;
    margin: 0 4rem;
  }

  /* === FEATURES === */
  .features {
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .section-desc {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    max-width: 550px;
    line-height: 1.7;
    margin-bottom: 4rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border-subtle);
    border: 1px solid var(--color-border-default);
    border-radius: 12px;
    overflow: hidden;
  }

  /* === CODE SECTION === */
  .code-section {
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* === CTA === */
  .cta {
    padding: 8rem 2rem;
    text-align: center;
  }

  .cta h2 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
  }

  .hl {
    background: linear-gradient(135deg, var(--color-warm-muted), var(--color-warm-bright));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta p {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    margin-bottom: 2.5rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .btn-cta-primary {
    background: var(--color-text-primary);
    color: var(--color-base-deep);
    border: none;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    font-family: inherit;
  }

  .btn-cta-primary:hover {
    background: #ffffff;
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.1);
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .code-section {
      grid-template-columns: 1fr;
      padding: 4rem 2rem;
    }
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }

    .hero {
      min-height: 70vh;
      padding: 3rem 1.5rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .features {
      padding: 4rem 1.5rem;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .sep {
      margin: 0 1.5rem;
    }

    .cta {
      padding: 4rem 1.5rem;
    }

    .cta h2 {
      font-size: 2rem;
    }

    .cta-actions {
      flex-direction: column;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .feature-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
