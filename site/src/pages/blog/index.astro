---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const dateLocale = locale === 'es' ? 'es-MX' : 'en-US';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft || import.meta.env.DEV)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString(dateLocale, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Blog — RaiSE" description="Thoughts on reliable AI-assisted software engineering, lean methodology, and building in public.">
  <section class="blog-listing">
    <div class="blog-header">
      <div class="section-label">// blog</div>
      <h1>Writing</h1>
      <p class="blog-desc">
        Thoughts on reliable AI-assisted engineering, lean methodology, and building in public.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="no-posts">No posts yet. Check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="post-link">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .blog-listing {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 8rem;
  }

  .blog-header {
    margin-bottom: 4rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
  }

  .blog-desc {
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .no-posts {
    color: var(--color-text-tertiary);
    font-style: italic;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .post-link {
    display: block;
    padding: 2rem;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
    transition: all 0.2s;
    margin-bottom: 1rem;
  }

  .post-link:hover {
    border-color: var(--color-border-default);
    background: var(--color-base-surface);
  }

  .post-link time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .post-link h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .post-link p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border-default);
    border-radius: 4px;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .blog-listing {
      padding: 2rem 1.5rem 4rem;
    }

    h1 {
      font-size: 1.75rem;
    }
  }
</style>
