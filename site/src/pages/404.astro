---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const homeHref = getLocalizedPath('/', locale);
const isEs = locale === 'es';
---

<BaseLayout title="404 — RaiSE">
  <section class="not-found">
    <img src="/logo.svg" alt="RaiSE Framework" class="not-found-logo" />
    <div class="error-code">404</div>
    <h1>{isEs ? 'Página no encontrada.' : 'Page not found.'}</h1>
    <p>{isEs ? 'La página que buscas no existe o fue movida.' : "The page you're looking for doesn't exist or has been moved."}</p>
    <a href={homeHref} class="back-link">&larr; {isEs ? 'Volver al inicio' : 'Back to home'}</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    text-align: center;
    padding: 4rem 2rem;
  }

  .not-found-logo {
    height: 64px;
    width: auto;
    opacity: 0.3;
    margin-bottom: 2rem;
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: 8rem;
    font-weight: 700;
    color: var(--color-border-default);
    line-height: 1;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--color-text-tertiary);
    margin-bottom: 2rem;
  }

  .back-link {
    color: var(--color-warm);
    text-decoration: none;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.8;
  }
</style>
