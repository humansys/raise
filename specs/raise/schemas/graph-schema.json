{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raise.dev/schemas/graph-schema.json",
  "title": "RaiSE Graph Schema",
  "description": "Schema for the relationship graph between rules, stored separately from individual rules",
  "type": "object",
  "required": ["version", "generated_date", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version for this graph format",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "generated_date": {
      "type": "string",
      "description": "ISO8601 timestamp of when this graph was generated",
      "format": "date-time",
      "examples": ["2026-01-28T10:30:00Z"]
    },
    "nodes": {
      "type": "array",
      "description": "List of rule nodes in the graph (references to rule IDs)",
      "items": {
        "type": "object",
        "required": ["id", "category", "confidence"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Rule ID that this node references",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
          },
          "category": {
            "type": "string",
            "description": "Category of the rule (denormalized for quick filtering)",
            "enum": ["naming", "architecture", "security", "style", "reliability", "testing", "documentation"]
          },
          "confidence": {
            "type": "number",
            "description": "Confidence score (denormalized for quick filtering)",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "description": "List of relationships between rules",
      "items": {
        "type": "object",
        "required": ["from", "to", "type", "reason"],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string",
            "description": "Source rule ID",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
          },
          "to": {
            "type": "string",
            "description": "Target rule ID",
            "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "description": "Type of relationship between rules",
            "enum": ["requires", "conflicts_with", "supersedes", "related_to"]
          },
          "reason": {
            "type": "string",
            "description": "Human-readable explanation of why this relationship exists",
            "maxLength": 200,
            "examples": [
              "Services typically depend on repositories for data access",
              "Old error pattern is replaced by new async pattern"
            ]
          }
        }
      }
    }
  }
}
