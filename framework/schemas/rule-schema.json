{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raise.dev/schemas/rule-schema.json",
  "title": "RaiSE Rule Schema",
  "description": "Schema for individual governance rules extracted by SAR and consumed by CTX",
  "type": "object",
  "required": [
    "id",
    "version",
    "status",
    "category",
    "confidence",
    "enforcement",
    "title",
    "intent",
    "pattern",
    "examples",
    "provenance"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier, slugified format (e.g., 'ts-repository-suffix')",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 64,
      "examples": ["ts-service-suffix", "py-async-error-handling", "react-component-naming"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this rule (e.g., '1.0.0')",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "2.1.0"]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status of the rule",
      "enum": ["draft", "active", "deprecated"]
    },
    "category": {
      "type": "string",
      "description": "Classification category for the rule",
      "enum": ["naming", "architecture", "security", "style", "reliability", "testing", "documentation"]
    },
    "confidence": {
      "type": "number",
      "description": "Confidence score based on adoption rate in codebase (0.0-1.0)",
      "minimum": 0.0,
      "maximum": 1.0,
      "examples": [0.95, 0.80, 0.72]
    },
    "enforcement": {
      "type": "string",
      "description": "How strictly this rule should be enforced based on confidence",
      "enum": ["hard", "strong", "moderate", "advisory", "none"]
    },
    "title": {
      "type": "string",
      "description": "Human-readable title, concise (<80 chars)",
      "maxLength": 80,
      "examples": ["Services must end with 'Service' suffix"]
    },
    "intent": {
      "type": "string",
      "description": "The 'why' behind this rule in ONE sentence",
      "maxLength": 200,
      "examples": ["Ensures consistent naming for service classes to improve codebase navigability"]
    },
    "pattern": {
      "type": "object",
      "description": "Detection pattern for identifying rule violations",
      "required": ["type", "query", "scope"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of pattern matching to use",
          "enum": ["ast-grep", "regex", "structural"]
        },
        "query": {
          "type": "string",
          "description": "The detection pattern/query string",
          "minLength": 1,
          "examples": ["class $NAME { $$$ }", "Service$"]
        },
        "scope": {
          "type": "string",
          "description": "File glob pattern defining where this rule applies",
          "examples": ["src/services/**/*.ts", "**/*.py", "src/components/**/*.tsx"]
        }
      }
    },
    "examples": {
      "type": "object",
      "description": "Code examples demonstrating correct and incorrect usage",
      "required": ["positive", "negative"],
      "additionalProperties": false,
      "properties": {
        "positive": {
          "type": "array",
          "description": "Examples that follow the rule (minimum 1)",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["code"],
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string",
                "description": "Code snippet that follows the rule"
              },
              "source": {
                "type": "string",
                "description": "Optional file path where this example was found"
              }
            }
          }
        },
        "negative": {
          "type": "array",
          "description": "Examples that violate the rule (minimum 1)",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["code", "fix"],
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string",
                "description": "Code snippet that violates the rule"
              },
              "fix": {
                "type": "string",
                "description": "How to correct the violation"
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "description": "Origin and extraction metadata for this rule",
      "required": ["source", "tool_version", "timestamp", "evidence_count"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "How this rule was created",
          "enum": ["sar-extracted", "manual", "hybrid"]
        },
        "tool_version": {
          "type": "string",
          "description": "Version of SAR or tool that extracted/created this rule",
          "examples": ["sar-1.0.0", "manual-v1"]
        },
        "timestamp": {
          "type": "string",
          "description": "ISO8601 timestamp of when the rule was created/updated",
          "format": "date-time",
          "examples": ["2026-01-28T10:30:00Z"]
        },
        "evidence_count": {
          "type": "integer",
          "description": "Number of code instances that support this rule",
          "minimum": 0,
          "examples": [42, 15, 3]
        }
      }
    }
  }
}
