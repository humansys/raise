# Jira Configuration for your project
# Copy to jira.yaml and fill in your values.
# Used by rai-cli and AI agents to interact with Jira without token-expensive discovery.
# Deterministic reference — agents read this instead of querying workflows each time.

# ─── Projects ────────────────────────────────────────────────────────────────

projects:
  MY_PROJECT:
    name: My Project
    category: Development
    description: Your project description
    board_type: scrum

# ─── Workflow (adjust IDs to match your Jira instance) ─────────────────────
# Run: rai backlog get-transitions <ISSUE_KEY> to discover your transition IDs.

workflow:
  states:
    - name: Backlog
      id: 11
      category: To Do
      description: Not yet prioritized

    - name: Selected for Development
      id: 21
      category: To Do
      description: Prioritized, ready to start

    - name: In Progress
      id: 31
      category: In Progress
      description: Actively being worked on

    - name: Done
      id: 41
      category: Done
      description: Completed and verified

  # Status name → transition ID mapping for McpJiraAdapter
  status_mapping:
    backlog: 11
    selected: 21
    in-progress: 31
    done: 41

  # Mapping from RaiSE lifecycle to Jira transitions
  lifecycle_mapping:
    story_start: 31        # → In Progress
    story_close: 41        # → Done
    epic_start: 31         # → In Progress
    epic_close: 41         # → Done
    selected: 21           # → Selected for Development
    backlog: 11            # → Backlog

# ─── Team ────────────────────────────────────────────────────────────────────
# Identifiers that work with MCP jira_create_issue / jira_update_issue assignee field.

team:
  - name: Your Name
    identifier: you@example.com
    role: lead-dev
    focus: product, architecture

# ─── Issue Types ─────────────────────────────────────────────────────────────

issue_types:
  - name: Epic
    description: "Rolling or bounded body of work. Contains Stories, Improvements, Spikes."
    when_to_use: "When work spans multiple deliverables or requires architectural direction."

  - name: Story
    description: "Delivers direct user or developer value — new capability, feature, UX."
    when_to_use: "When the output is something a stakeholder can use or observe."

  - name: Improvement
    description: "Makes something existing better — process, tooling, DX, quality. Not a defect."
    when_to_use: "When nothing is broken but something could work better."

  - name: Spike
    description: "Time-boxed investigation. Produces knowledge, NOT a deliverable."
    when_to_use: "When uncertainty must be reduced before committing to a Story or design."

  - name: Task
    description: "Technical work with no direct user value. Infrastructure, CI, config, maintenance."
    when_to_use: "When the work is necessary but doesn't fit Story, Improvement, or Spike."

  - name: Bug
    description: "Something that worked and broke, or never worked as specified."
    when_to_use: "Defect. Use priority field for severity (Critical/Major/Minor)."

  - name: Sub-task
    description: "Child of any issue type. For breaking down complex work within a single issue."
    note: "Use 'Sub-task' NOT 'Subtask' — Jira API is case-sensitive."

# ─── Usage Notes for Agents ─────────────────────────────────────────────────
#
# To assign an issue:
#   Use the 'identifier' field from the team section as the assignee value.
#
# To transition an issue:
#   Use mcp__atlassian__jira_transition_issue with the state 'id' from workflow.states.
#
# To link a story to an epic:
#   Use additional_fields: {"parent": "PROJECT-XXX"} when creating the issue.
