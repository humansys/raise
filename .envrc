#!/usr/bin/env bash
# Automatically load .env for JIRA OAuth credentials
# Usage: source .envrc (or use direnv: https://direnv.net/)

if [ -f .env ]; then
    export $(grep -v '^#' .env | xargs)
    # Only echo in interactive shells — stdout pollution breaks Claude Code hooks
    [[ $- == *i* ]] && echo "✓ JIRA OAuth env vars loaded from .env"
else
    [[ $- == *i* ]] && echo "⚠ Warning: .env file not found"
fi
